const ICON_STYLES: Record<string, { bg: string; color: string }> = {
  youtube: { bg: "oklch(0.91 0.07 27)", color: "oklch(0.45 0.17 27)" },
  github: { bg: "oklch(0.92 0.012 95)", color: "oklch(0.28 0.013 95)" },
  instagram: { bg: "oklch(0.90 0.06 30)", color: "oklch(0.40 0.10 30)" },
  dev: { bg: "oklch(0.91 0.04 230)", color: "oklch(0.42 0.10 230)" },
  camera: { bg: "oklch(0.90 0.055 150)", color: "oklch(0.42 0.085 150)" },
};
---

<Base title="Links — Juan R.">
  <!-- Full-screen gradient wrapper (body can't be targeted from slot) -->
  <div
    class="min-h-screen flex flex-col items-center px-5 pt-12 pb-20 antialiased bg-[linear-gradient(165deg,oklch(0.93_0.055_80),oklch(0.88_0.06_25)_55%,oklch(0.86_0.06_320))]"
  >
    <main class="w-full max-w-115 flex flex-col gap-6.5">
      <!-- Profile -->
      <section class="flex flex-col items-center gap-3 text-center">
        <div
          class="w-26 h-26 rounded-full ph shrink-0 shadow-[0_0_0_5px_oklch(1_0_0/0.55)]"
        >
          <span class="tag">profile photo</span>
        </div>
        <h1
          class="font-display font-semibold text-[30px] tracking-[-0.01em] text-ink"
        >
          Juan R.
        </h1>
        <p class="text-[15px] leading-normal max-w-[34ch] text-ink opacity-85">
          part-time human, full-time tab hoarder. here's where i live on the
          internet ↓
        </p>
        <div class="flex gap-2 flex-wrap justify-center mt-0.5">
          <span
            class="text-[12.5px] px-3 py-1.25 rounded-full bg-white/70 border border-line text-ink-soft backdrop-blur-sm"
            >📍 Probably In The Mountains</span
          >
          <span
            class="text-[12.5px] px-3 py-1.25 rounded-full bg-white/70 border border-line text-ink-soft backdrop-blur-sm"
            >He/Him/His</span
          >
        </div>
      </section>

      <!-- Links -->
      <section class="flex flex-col gap-3">
        {
          links.map((link) => {
            const iconPath = ICONS[link.platform] ?? "";
            const iconStyle = ICON_STYLES[link.platform];
            return (
              <a
                href={link.href}
                class="flex items-center gap-3.5 no-underline text-ink bg-surface border border-line rounded-[20px] px-4 py-3 shadow-card min-h-16 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-raised"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span
                  class="w-11 h-11 shrink-0 rounded-full grid place-items-center font-mono text-[13px] font-medium text-ink-soft bg-surface-2 border border-line"
                  style={
                    iconStyle
                      ? `background:${iconStyle.bg};color:${iconStyle.color}`
                      : ""
                  }
                >
                  {iconPath ? (
                    <svg
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      width="20"
                      height="20"
                      aria-hidden="true"
                    >
                      <path d={iconPath} />
                    </svg>
                  ) : (
                    link.platform.slice(0, 2).toUpperCase()
                  )}
                </span>
                <span class="flex flex-col gap-0.5 flex-1 min-w-0">
                  <span class="font-medium text-[15.5px]">{link.label}</span>
                  {link.sublabel && (
                    <span class="text-[12.5px] text-ink-soft font-mono">
                      {link.sublabel}
                    </span>
                  )}
                </span>
                <span
                  class="text-ink-soft text-[18px] shrink-0"
                  aria-hidden="true"
                >
                  →
                </span>
              </a>
            );
          })
        }
      </section>

      <footer
        class="text-center font-mono text-xs text-ink-soft opacity-75 mt-1.5"
      >
        juanr.links
      </footer>
    </main>
  </div>
</Base>
