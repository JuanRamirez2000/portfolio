---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getPhotos } from '../../lib/api';
import { cfImageUrl, cfImageSrcset } from '../../lib/cf-images';

export async function getStaticPaths() {
  const photos = await getPhotos();
  return photos.map((photo) => ({
    params: { id: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props;

const galleryLabels: Record<string, string> = {
  portraits: 'Portraits',
  landscape: 'Landscape',
  grad: 'Grad',
  boudoir: 'Boudoir',
};

const ogImage = cfImageUrl(photo.id, 'gallery');
---

<Base title={`${photo.title} — juanr.photo`}>
  <Fragment slot="head">
    <meta property="og:title" content={`${photo.title} — juanr.photo`} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
  </Fragment>

  <div class="relative min-h-screen font-sans antialiased overflow-hidden">

    <!-- Blurred photo background — colors bleed from the image itself -->
    <div class="absolute inset-0 z-0">
      <img
        src={cfImageUrl(photo.id, 'gallery')}
        alt=""
        aria-hidden="true"
        class="w-full h-full object-cover scale-125 blur-[72px] opacity-80"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <div class="relative z-10">
      <Nav />
    </div>

    <main class="relative z-10 min-h-screen flex flex-col items-center justify-center px-6 pt-20 pb-16">
      <img
        src={cfImageUrl(photo.id, 'gallery')}
        srcset={cfImageSrcset(photo.id)}
        sizes="(min-width: 1024px) 70vw, 90vw"
        alt={photo.alt}
        class="max-h-[78vh] max-w-full object-contain rounded-2xl shadow-[0_40px_120px_-16px_oklch(0_0_0/0.6)]"
        loading="eager"
        decoding="async"
      />

      <div class="mt-8 text-center">
        <h1 class="font-display font-medium text-[26px] text-white tracking-[-0.01em] [text-shadow:0_2px_16px_oklch(0_0_0/0.4)]">
          {photo.title}
        </h1>
        <div class="flex items-center justify-center gap-2 mt-3.5 flex-wrap">
          {photo.galleries.map((slug) => (
            <a
              href={`/galleries/${slug}`}
              class="font-mono text-[11.5px] text-white/85 bg-white/12 border border-white/20 rounded-full px-3 py-1 hover:bg-white/22 hover:text-white transition-colors no-underline backdrop-blur-sm"
            >
              {galleryLabels[slug] ?? slug}
            </a>
          ))}
          <span class="font-mono text-[11.5px] text-white/50">{photo.year}</span>
        </div>
      </div>
    </main>
  </div>
</Base>
