---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getPhotos } from '../../lib/api';
import { cfImageUrl, cfImageSrcset } from '../../lib/cf-images';
import type { Photo } from '../../lib/cf-images';

export async function getStaticPaths() {
  const photos = await getPhotos();
  return photos.map((photo, idx) => ({
    params: { id: photo.id },
    props: {
      photo,
      prev: photos[idx - 1] ?? null,
      next: photos[idx + 1] ?? null,
    },
  }));
}

interface Props {
  photo: Photo;
  prev: Photo | null;
  next: Photo | null;
}

const { photo, prev, next } = Astro.props;

const galleryLabels: Record<string, string> = {
  portraits: 'Portraits',
  landscape: 'Landscape',
  grad: 'Grad',
  boudoir: 'Boudoir',
};

const ogImage = cfImageUrl(photo.id, 'gallery');
---

<Base title={`${photo.title} — juanr.photo`}>
  <Fragment slot="head">
    <meta property="og:title" content={`${photo.title} — juanr.photo`} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
  </Fragment>

  <div class="relative min-h-screen font-sans antialiased overflow-hidden">

    <!-- Blurred ambient background -->
    <div class="absolute inset-0 z-0">
      <img
        src={cfImageUrl(photo.id, 'gallery')}
        alt=""
        aria-hidden="true"
        class="w-full h-full object-cover scale-125 blur-[72px] opacity-80"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <div class="relative z-10">
      <Nav transition:persist />
    </div>

    <main class="relative z-10 min-h-screen flex flex-col items-center justify-center px-6 pt-20 pb-16">
      <img
        src={cfImageUrl(photo.id, 'gallery')}
        srcset={cfImageSrcset(photo.id)}
        sizes="(min-width: 1024px) 70vw, 90vw"
        alt={photo.alt}
        transition:name={`photo-${photo.id}`}
        class="max-h-[78vh] max-w-full object-contain rounded-2xl shadow-[0_40px_120px_-16px_oklch(0_0_0/0.6)]"
        loading="eager"
        decoding="async"
      />

      <!-- Metadata -->
      <div class="mt-8 text-center">
        <h1 class="font-display font-medium text-[26px] text-white tracking-[-0.01em] [text-shadow:0_2px_16px_oklch(0_0_0/0.4)]">
          {photo.title}
        </h1>
        <div class="flex items-center justify-center gap-2 mt-3.5 flex-wrap">
          {photo.galleries.map((slug) => (
            <a
              href={`/galleries/${slug}`}
              class="font-mono text-[11.5px] text-white/85 bg-white/12 border border-white/20 rounded-full px-3 py-1 hover:bg-white/22 hover:text-white transition-colors no-underline backdrop-blur-sm"
            >
              {galleryLabels[slug] ?? slug}
            </a>
          ))}
          <span class="font-mono text-[11.5px] text-white/50">{photo.year}</span>
        </div>
      </div>

      <!-- Prev / Next -->
      <div class="mt-10 flex items-center gap-4">
        {prev ? (
          <a
            id="lb-page-prev"
            href={`/photos/${prev.id}`}
            class="flex items-center gap-2 font-mono text-[12px] text-white/70 bg-white/10 hover:bg-white/18 border border-white/20 rounded-full px-4 py-2.5 transition-colors no-underline backdrop-blur-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            prev
          </a>
        ) : <span />}
        {next ? (
          <a
            id="lb-page-next"
            href={`/photos/${next.id}`}
            class="flex items-center gap-2 font-mono text-[12px] text-white/70 bg-white/10 hover:bg-white/18 border border-white/20 rounded-full px-4 py-2.5 transition-colors no-underline backdrop-blur-sm"
          >
            next
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        ) : <span />}
      </div>
    </main>
  </div>
</Base>

<script>
  const prevEl = document.getElementById('lb-page-prev') as HTMLAnchorElement | null;
  const nextEl = document.getElementById('lb-page-next') as HTMLAnchorElement | null;

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft'  && prevEl) prevEl.click();
    if (e.key === 'ArrowRight' && nextEl) nextEl.click();
  });
</script>
