---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Lightbox from "../components/Lightbox.astro";
import { getFeaturedPhotos, getHero } from "../lib/api";
import { cfImageUrl, cfImageSrcset, cfHeroSrcset } from "../lib/cf-images";

const [featuredPhotos, heroPhotoId] = await Promise.all([
  getFeaturedPhotos(),
  getHero("landing"),
]);
---

<Base title="juanr.photo — Photography by Juan R.">
  <div class="bg-bg font-sans text-ink antialiased">
    <Nav />

    <!-- HERO -->
    <header
      class="relative h-screen min-h-[600px] grid place-items-center overflow-hidden"
    >
      {
        heroPhotoId ? (
          <img
            src={cfImageUrl(heroPhotoId, "hero")}
            srcset={cfHeroSrcset(heroPhotoId)}
            sizes="100vw"
            alt="hero"
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div
            class="absolute inset-0 border-0 rounded-none ph"
            style="background:repeating-linear-gradient(45deg,oklch(0.42 0.012 250) 0 16px,oklch(0.38 0.012 250) 16px 32px)"
          >
            <span
              class="tag"
              style="background:oklch(0 0 0/0.35);color:oklch(1 0 0/0.9);border-color:oklch(1 0 0/0.25)"
            >
              full-bleed hero image
            </span>
          </div>
        )
      }
      <!-- Scrim -->
      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,oklch(0_0_0/0.35)_0%,oklch(0_0_0/0.05)_35%,oklch(0_0_0/0.45)_100%)]"
        aria-hidden="true"
      >
      </div>
      <!-- Content -->
      <div class="relative text-center text-white px-6 z-10">
        <div
          class="font-mono text-[13px] tracking-[0.18em] uppercase opacity-85 mb-4.5"
        >
          Photography by Juan R.
        </div>
        <h1
          class="font-display font-medium text-[clamp(44px,7vw,84px)] leading-none tracking-[-0.01em] [text-shadow:0_2px_20px_oklch(0_0_0/0.4)]"
        >
          Light Worth Chasing.
        </h1>
      </div>
      <!-- Scroll hint -->
      <div
        class="absolute bottom-7.5 left-1/2 -translate-x-1/2 z-10 text-white/85 font-mono text-[11px] tracking-[0.1em] flex flex-col items-center gap-2"
        aria-hidden="true"
      >
        <span>TOP PICKS</span>
        <span class="w-px h-8.5 bg-white/60"></span>
      </div>
    </header>

    <!-- TOP PICKS -->
    <section class="py-20 pb-24 w-full max-w-295 2xl:max-w-350 3xl:max-w-400 mx-auto px-8">
      {
        featuredPhotos.length > 0 ? (
          <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 2xl:columns-5 3xl:columns-6 gap-4.5">
            {featuredPhotos.map((photo) => (
              <div class="break-inside-avoid mb-4.5 rounded-[20px] overflow-hidden">
                <img
                  src={cfImageUrl(photo.id, "thumbnail")}
                  srcset={cfImageSrcset(photo.id)}
                  sizes="(min-width: 1920px) 17vw, (min-width: 1536px) 20vw, (min-width: 1280px) 25vw, (min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                  alt={photo.alt}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-auto block cursor-pointer"
                  transition:name={`photo-${photo.id}`}
                  data-lightbox
                  data-lb-src={cfImageUrl(photo.id, "gallery")}
                  data-lb-alt={photo.alt}
                  data-lb-id={photo.id}
                />
              </div>
            ))}
          </div>
        ) : (
          <p class="text-center text-ink-soft font-mono text-[13px] py-20">
            // nothing featured yet
          </p>
        )
      }
    </section>

    <Lightbox />

    <!-- FOOTER -->
    <footer class="border-t border-line">
      <div
        class="w-full max-w-295 mx-auto px-8 py-11 flex items-center justify-between flex-wrap gap-3.5 font-mono text-[12.5px] text-ink-soft"
      >
        <span class="font-display font-semibold text-[18px] text-ink"
          >juanr.photo</span
        >
        <span>Juan R. - Made with love</span>
      </div>
    </footer>
  </div>
</Base>
