---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import AgeGate from '../../components/AgeGate.astro';
import { cfImageUrl, cfImageSrcset } from '../../lib/cf-images';
import { getPhotos } from '../../lib/api';
import type { Ratio } from '../../lib/cf-images';

const photos = await getPhotos('boudoir');

const ratioDims: Record<Ratio, { width: number; height: number }> = {
  tall:   { width: 400, height: 533 },
  wide:   { width: 400, height: 300 },
  square: { width: 400, height: 400 },
};
---

<Base title="Boudoir — juanr.photo">
  <div class="bg-bg font-sans text-ink antialiased">

    <AgeGate />
    <Nav />

    <!-- HERO -->
    <header class="relative h-screen min-h-[600px] grid place-items-center overflow-hidden">
      <div class="absolute inset-0 ph border-0 rounded-none" style="background:repeating-linear-gradient(45deg,oklch(0.42 0.012 250) 0 16px,oklch(0.38 0.012 250) 16px 32px)">
        <span class="tag" style="background:oklch(0 0 0/0.35);color:oklch(1 0 0/0.9);border-color:oklch(1 0 0/0.25)">boudoir hero image</span>
      </div>
      <div class="absolute inset-0 bg-[linear-gradient(180deg,oklch(0_0_0/0.35)_0%,oklch(0_0_0/0.05)_35%,oklch(0_0_0/0.45)_100%)]" aria-hidden="true"></div>
      <div class="relative text-center text-white px-6 z-10">
        <div class="font-mono text-[13px] tracking-[0.18em] uppercase opacity-85 mb-4.5">GALLERY · 18+</div>
        <h1 class="font-display font-medium text-[clamp(44px,7vw,84px)] leading-none tracking-[-0.01em] [text-shadow:0_2px_20px_oklch(0_0_0/0.4)]">Boudoir</h1>
        <p class="text-[17px] mt-5 opacity-[0.92]">intimate, intentional, 18+</p>
      </div>
      <div class="absolute bottom-7.5 left-1/2 -translate-x-1/2 z-10 text-white/85 font-mono text-[11px] tracking-[0.1em] flex flex-col items-center gap-2" aria-hidden="true">
        <span>PHOTOS</span>
        <span class="w-px h-8.5 bg-white/60"></span>
      </div>
    </header>

    <!-- GALLERY GRID -->
    <section class="py-20 pb-24 w-full max-w-[1180px] mx-auto px-8">
      {photos.length > 0 ? (
        <div class="columns-1 sm:columns-2 lg:columns-3 gap-4.5">
          {photos.map((photo) => (
            <div class="break-inside-avoid mb-4.5 rounded-[20px] overflow-hidden">
              <img
                src={cfImageUrl(photo.id, 'thumbnail')}
                srcset={cfImageSrcset(photo.id)}
                sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                alt={photo.alt}
                width={ratioDims[photo.ratio].width}
                height={ratioDims[photo.ratio].height}
                loading="lazy"
                decoding="async"
                class="w-full block"
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="text-center text-ink-soft font-mono text-[13px] py-20">// coming soon</p>
      )}
    </section>

    <!-- FOOTER -->
    <footer class="border-t border-line">
      <div class="w-full max-w-[1180px] mx-auto px-8 py-11 flex items-center justify-between flex-wrap gap-3.5 font-mono text-[12.5px] text-ink-soft">
        <span class="font-display font-semibold text-[18px] text-ink">juanr.photo</span>
        <span>Juan R. - Made with love</span>
      </div>
    </footer>
  </div>
</Base>
