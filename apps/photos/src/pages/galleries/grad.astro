---
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import { getPhotos, getHero } from '../../lib/api';

const [photos, heroPhotoId] = await Promise.all([getPhotos('grad'), getHero('grad')]);
---

<GalleryLayout
  title="Graduation — juanr.photo"
  galleryName="Graduation"
  tagline="capturing success"
  heroLabel="graduation hero image"
  heroPhotoId={heroPhotoId}
  photos={photos}
/>
