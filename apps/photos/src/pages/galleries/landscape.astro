---
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import photosData from '../../data/photos.json';
import type { Photo } from '../../lib/cf-images';

const photos = (photosData as Photo[]).filter(
  p => p.gallery.includes('landscape') && !p.id.startsWith('REPLACE')
);
---

<GalleryLayout
  title="Landscape — juanr.photo"
  galleryName="Landscape"
  tagline="the world when nobody's looking"
  heroLabel="landscape hero image"
  photos={photos}
/>
