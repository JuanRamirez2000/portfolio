---
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import { getPhotos, getHero } from '../../lib/api';

const [photos, heroPhotoId] = await Promise.all([getPhotos('landscape'), getHero('landscape')]);
---

<GalleryLayout
  title="Landscape — juanr.photos"
  galleryName="Landscape"
  tagline="the world when nobody's looking"
  heroLabel="landscape hero image"
  heroPhotoId={heroPhotoId}
  photos={photos}
/>
