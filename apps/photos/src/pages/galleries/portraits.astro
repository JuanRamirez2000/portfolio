---
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import photosData from '../../data/photos.json';
import type { Photo } from '../../lib/cf-images';

const photos = (photosData as Photo[]).filter(
  p => p.gallery.includes('portraits') && !p.id.startsWith('REPLACE')
);
---

<GalleryLayout
  title="Portraits — juanr.photo"
  galleryName="Portraits"
  tagline="faces, moods, and the occasional glare"
  heroLabel="portraits hero image"
  photos={photos}
/>
