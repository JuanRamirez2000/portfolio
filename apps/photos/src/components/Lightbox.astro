---
---

<div
  id="lightbox"
  class="fixed inset-0 z-[200] flex items-center justify-center hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Photo viewer"
>
  <div id="lb-backdrop" class="absolute inset-0 bg-black/90 cursor-pointer"></div>

  <!-- Prev -->
  <button
    id="lb-prev"
    aria-label="Previous photo"
    class="absolute left-3 sm:left-5 top-1/2 -translate-y-1/2 z-20 flex items-center justify-center w-10 h-10 bg-white/12 hover:bg-white/22 border border-white/20 text-white rounded-full transition-colors duration-150 backdrop-blur-sm disabled:opacity-20 disabled:pointer-events-none"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>

  <img
    id="lb-img"
    src=""
    alt=""
    class="relative z-10 max-w-[80vw] max-h-[88vh] object-contain rounded-2xl shadow-[0_32px_80px_-12px_oklch(0_0_0/0.7)]"
    style="transition: opacity 180ms ease"
  />

  <!-- Next -->
  <button
    id="lb-next"
    aria-label="Next photo"
    class="absolute right-3 sm:right-5 top-1/2 -translate-y-1/2 z-20 flex items-center justify-center w-10 h-10 bg-white/12 hover:bg-white/22 border border-white/20 text-white rounded-full transition-colors duration-150 backdrop-blur-sm disabled:opacity-20 disabled:pointer-events-none"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>

  <!-- Controls top-right -->
  <div class="absolute top-5 right-5 z-20 flex gap-2">
    <button
      id="lb-copy"
      title="Copy link to photo"
      class="flex items-center gap-1.5 bg-white/12 hover:bg-white/22 border border-white/20 text-white/90 text-[12.5px] font-mono px-3.5 py-2 rounded-full transition-colors duration-150 backdrop-blur-sm"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
      </svg>
      copy link
    </button>
    <button
      id="lb-close"
      aria-label="Close photo viewer"
      class="flex items-center justify-center w-9 h-9 bg-white/12 hover:bg-white/22 border border-white/20 text-white/90 rounded-full transition-colors duration-150 backdrop-blur-sm"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Counter -->
  <div
    id="lb-counter"
    class="absolute bottom-5 left-1/2 -translate-x-1/2 z-20 font-mono text-[11px] text-white/45 pointer-events-none"
  ></div>

  <!-- Toast -->
  <div
    id="lb-toast"
    class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 bg-surface border border-line text-ink text-[12.5px] font-mono px-4 py-2.5 rounded-full shadow-lg hidden pointer-events-none"
  >
    link copied ✓
  </div>
</div>

<script>
  let currentIdx = 0;
  let currentId  = '';
  let ctrl: AbortController | null = null;

  // Restore scroll if navigation happens while lightbox is open
  document.addEventListener('astro:before-swap', () => {
    document.body.style.overflow = '';
  });

  document.addEventListener('astro:page-load', () => {
    // Abort stale listeners from the previous page, then get fresh ones
    ctrl?.abort();
    ctrl = new AbortController();
    const { signal } = ctrl;

    const lb       = document.getElementById('lightbox');
    if (!lb) return;

    const lbImg    = document.getElementById('lb-img') as HTMLImageElement;
    const backdrop = document.getElementById('lb-backdrop')!;
    const prevBtn  = document.getElementById('lb-prev') as HTMLButtonElement;
    const nextBtn  = document.getElementById('lb-next') as HTMLButtonElement;
    const closeBtn = document.getElementById('lb-close')!;
    const copyBtn  = document.getElementById('lb-copy')!;
    const counter  = document.getElementById('lb-counter')!;
    const toast    = document.getElementById('lb-toast')!;

    function getAll() {
      return Array.from(document.querySelectorAll('[data-lightbox]'));
    }

    function updateControls() {
      const all = getAll();
      prevBtn.disabled = currentIdx === 0;
      nextBtn.disabled = currentIdx === all.length - 1;
      counter.textContent = all.length > 1 ? `${currentIdx + 1} / ${all.length}` : '';
    }

    function openIdx(idx: number) {
      const all = getAll();
      if (idx < 0 || idx >= all.length) return;

      const el     = all[idx];
      const newSrc = el.getAttribute('data-lb-src') ?? '';
      const newAlt = el.getAttribute('data-lb-alt') ?? '';
      const newId  = el.getAttribute('data-lb-id') ?? '';
      const isOpen = !lb.classList.contains('hidden');

      currentIdx = idx;
      currentId  = newId;
      updateControls();

      if (isOpen) {
        // Crossfade between images
        lbImg.style.opacity = '0';
        setTimeout(() => {
          lbImg.src = newSrc;
          lbImg.alt = newAlt;
          lbImg.style.opacity = '1';
        }, 180);
      } else {
        lbImg.src = newSrc;
        lbImg.alt = newAlt;
        lb.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    }

    function close() {
      lb.classList.add('hidden');
      lbImg.src = '';
      currentId = '';
      document.body.style.overflow = '';
    }

    document.addEventListener('click', (e) => {
      const el = (e.target as Element).closest('[data-lightbox]');
      if (!el) return;
      const all = getAll();
      const idx = all.indexOf(el);
      openIdx(idx >= 0 ? idx : 0);
    }, { signal });

    prevBtn.addEventListener('click', () => openIdx(currentIdx - 1), { signal });
    nextBtn.addEventListener('click', () => openIdx(currentIdx + 1), { signal });
    backdrop.addEventListener('click', close, { signal });
    closeBtn.addEventListener('click', close, { signal });

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape')     close();
      if (e.key === 'ArrowLeft')  openIdx(currentIdx - 1);
      if (e.key === 'ArrowRight') openIdx(currentIdx + 1);
    }, { signal });

    copyBtn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(`${location.origin}/photos/${currentId}`);
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2000);
    }, { signal });
  });
</script>
