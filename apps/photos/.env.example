# Cloudflare Images
# Found at: dash.cloudflare.com > Images > Overview (top of page)
# This is NOT a secret — it ends up embedded in your HTML URLs anyway.
PUBLIC_CF_IMAGES_ACCOUNT_HASH=your_account_hash_here

# Photos Worker API URL (your deployed Cloudflare Worker)
PUBLIC_WORKER_URL=https://portfolio-photos-worker.your-subdomain.workers.dev

# Cloudflare Web Analytics token (not a secret — safe to commit)
# Found at: dash.cloudflare.com > Analytics & Logs > Web Analytics > your site > Manage site
PUBLIC_CF_ANALYTICS_TOKEN=your_analytics_token_here
